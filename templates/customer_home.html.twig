    <style>
		.rowActive {background-color:#ffffee;cursor:pointer;}
        .rowSelected {background-color:#AB0520;}
        #resTable,#resTable td {cursor:pointer;}
    </style>

    <script>
    $("#resTable").on("mouseenter","tr",function() {
                $(this).find('td').addClass( "rowActive" );
            }).on("mouseleave","tr",function() {
                $(this).find('td').removeClass( "rowActive" );
            }).on("click","tr",function() {
                $(this).find('td').addClass("rowSelected");
            });
    </script>

